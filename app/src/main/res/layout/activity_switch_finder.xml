<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".activities.SwitchFinderActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/switch_finder_toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            style="?toolbarStyle" />
    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Status header: spinner + friendly status + elapsed seconds -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/card_content_padding">

            <ProgressBar
                android:id="@+id/switch_finder_progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:layout_marginRight="16dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/switch_finder_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/find_switch_status_starting"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="16sp"
                    tools:text="Testing switches…" />

                <TextView
                    android:id="@+id/switch_finder_elapsed"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="13sp"
                    tools:text="12s elapsed" />
            </LinearLayout>
        </LinearLayout>

        <!-- Result card: shown on completion only -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/switch_finder_result_card"
            style="@style/Widget.MaterialComponents.CardView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/card_margin"
            android:layout_marginRight="@dimen/card_margin"
            android:layout_marginBottom="@dimen/card_margin"
            android:visibility="gone"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="3dp"
            app:contentPadding="@dimen/card_content_padding"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/switch_finder_result_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="16sp"
                    tools:text="Found: /sys/... 1 0 (cut, verified)" />

                <TextView
                    android:id="@+id/switch_finder_result_caveat"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/card_content_margin"
                    android:text="@string/verified_switch_needs_test_caveat"
                    android:textSize="14sp"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <!-- Inline Apply progress (spinner + status), hidden until Apply is tapped -->
                <LinearLayout
                    android:id="@+id/switch_finder_apply_progress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/card_content_margin"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <ProgressBar
                        android:id="@+id/switch_finder_apply_spinner"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="12dp"
                        android:layout_marginRight="12dp" />

                    <TextView
                        android:id="@+id/switch_finder_apply_status"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="?android:attr/textColorPrimary"
                        android:textSize="14sp"
                        tools:text="Testing the switch live…" />
                </LinearLayout>

                <Button
                    android:id="@+id/switch_finder_apply_button"
                    style="@style/Widget.AppCompat.Button.Colored"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="@dimen/card_content_padding"
                    android:text="@string/find_switch_apply"
                    android:textColor="@color/color_surface" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Live, auto-scrolling log of exactly what the device is doing -->
        <ScrollView
            android:id="@+id/switch_finder_log_scroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginLeft="@dimen/card_margin"
            android:layout_marginRight="@dimen/card_margin"
            android:fillViewport="true"
            android:scrollbars="vertical">

            <TextView
                android:id="@+id/switch_finder_log"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="16dp"
                android:textColor="?android:attr/textColorSecondary"
                android:textIsSelectable="true"
                android:textSize="12sp"
                android:typeface="monospace" />
        </ScrollView>

        <Button
            android:id="@+id/switch_finder_cancel_button"
            style="@style/Widget.AppCompat.Button.Colored"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/card_margin"
            android:text="@string/find_switch_cancel"
            android:textColor="@color/color_surface" />

    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
